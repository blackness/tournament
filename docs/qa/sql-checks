7. Audit match linkage by team (division-wide)
sql

Copy code
select
  tt.id as team_id,
  tt.name as team_name,
  tt.pool_id,
  count(m.id) as total_matches_linked,
  count(*) filter (where m.status in ('complete', 'forfeit')) as completed_matches_linked
from tournament_teams tt
left join matches m
  on m.team_a_id = tt.id
  or m.team_b_id = tt.id
where tt.division_id = 'YOUR_DIVISION_ID'
group by tt.id, tt.name, tt.pool_id
order by tt.pool_id, tt.name;

