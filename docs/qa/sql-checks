16. Detect cross-pool bad standings rows
These are standings rows where the team's actual tournament_teams.pool_id does not match the pool_standings.pool_id.

sql

Copy code
select
  ps.id as pool_standings_id,
  ps.pool_id as standings_pool_id,
  tt.pool_id as actual_team_pool_id,
  ps.team_id,
  tt.name,
  ps.games_played,
  ps.wins,
  ps.losses,
  ps.rank
from pool_standings ps
join tournament_teams tt
  on tt.id = ps.team_id
join pools p
  on p.id = ps.pool_id
where p.division_id = 'YOUR_DIVISION_ID'
  and tt.pool_id is distinct from ps.pool_id
order by ps.pool_id, tt.name;

17. Delete cross-pool bad standings rows for a division
Use only after inspecting the rows first.

sql

Copy code
delete from pool_standings ps
using tournament_teams tt, pools p
where tt.id = ps.team_id
  and p.id = ps.pool_id
  and p.division_id = 'YOUR_DIVISION_ID'
  and tt.pool_id is distinct from ps.pool_id;

18. Recompute standings once per pool in a division
sql

Copy code
select fn_recompute_standings(m.id)
from matches m
where m.id in (
  select distinct on (pool_id) id
  from matches
  where division_id = 'YOUR_DIVISION_ID'
    and pool_id is not null
    and bracket_type is null
    and status in ('complete', 'forfeit')
  order by pool_id, id
);

